EPX_PUBLIC_KEY=eyAidGVybWluYWxQcm9maWxlSWQiOiAiNzJjNzg5OTEtYTdjNS00NTQwLWE0YzgtNDUyM2UxOTgxNTc2IiB9
EPX_TERMINAL_PROFILE_ID=72c78991-a7c5-4540-a4c8-4523e1981576
