{
    "git.ignoreLimitWarning": true,
    "mssql.intelliSense.enableErrorChecking": false,
    "mssql.autoDisableNonTSqlLanguageService": true,
    "files.associations": {
        "migrations/*.sql": "postgres",
        "**/migrations/*.sql": "postgres"
    },
    "chat.tools.terminal.autoApprove": {
        "npm --prefix client": true
    }
}